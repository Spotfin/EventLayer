{
    "name": "spotfin/eventlayer",
    "description": "WordPress Plugin for managing custom DataLayer and GTM Events",
    "type": "wordpress-plugin",
    "keywords": [
        "wordpress",
        "plugin",
        "analytics",
        "google-analytics",
        "gtm",
        "data-layer"
    ],
    "homepage": "https://eventlayerpro.com",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Spotfin Creative",
            "homepage": "https://spotfincreative.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "EventLayer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EventLayer\\Tests\\": "src/Tests/"
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "phpcs:src": "phpcs src/",
        "phpcbf:src": "phpcbf src/",
        "phpcs:main": "phpcs eventlayer.php",
        "phpcbf:main": "phpcbf eventlayer.php",
        "lint": "phpcs --report=summary",
        "fix": "phpcbf"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}